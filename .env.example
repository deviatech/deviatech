# Resend (https://resend.com) — used by src/app/api/contact/route.ts
RESEND_API_KEY=

# Where contact form submissions are sent. Defaults to site.email if unset.
CONTACT_TO_EMAIL=deviatechcom@gmail.com

# Must be an address on a domain verified in Resend, e.g. "DeviaTech <hello@deviatech.com>".
# Until you verify deviatech.com in Resend, leave this unset to use Resend's
# sandbox sender (onboarding@resend.dev) — sandbox mode only delivers to the
# email address you signed up to Resend with.
CONTACT_FROM_EMAIL=
